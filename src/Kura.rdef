/*
 * Sidebar icons. Groups use the "folder" resource (13) above; the
 * root item uses the "icon-root" resource if present, otherwise the
 * app icon. To provide a dedicated root icon, uncomment and point
 * the import at an HVIF file:
 *
 * resource(23, "icon-root") #'VICN' import "artwork/root.hvif";
 *
 * Per-group custom icons are also possible: any 'VICN' resource
 * added here can be referenced by name via a group's icon field.
 */

